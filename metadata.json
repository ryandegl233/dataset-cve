{
  "cve": "CVE-2019-17671",
  "application": "WordPress",
  "environment": {
    "platform": "Ubuntu VM",
    "orchestration": "Kubernetes (kind)",
    "namespaces": [
      "wp-vuln",
      "wp-fixed"
    ]
  },
  "attack": {
    "payload": "GET /?static=1",
    "scripts": [
      "attack_vuln_tagged.sh",
      "attack_fixed_tagged.sh"
    ]
  },
  "evidence": {
    "syscall_traces": [
      "logs/vuln.scap",
      "logs/fixed.scap"
    ],
    "network_traces": [
      "logs/vuln.pcap",
      "logs/fixed.pcap"
    ],
    "http_headers": [
      "artifacts/vuln_response_headers.txt",
      "artifacts/fixed_response_headers.txt"
    ]
  },
  "ground_truth": {
    "markers": [
      "ATTACK_START",
      "ATTACK_STOP"
    ],
    "mechanism": "logger"
  },
  "vulnerability_behavior": {
    "vulnerable": {
      "X-Static-PublicQv": 1,
      "X-Static-InQueryVars": 1
    },
    "fixed": {
      "X-Static-PublicQv": 0,
      "X-Static-InQueryVars": 0
    }
  }
}
